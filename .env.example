# Required: encryption key for encrypting stored API tokens
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters
ENCRYPTION_KEY=

# Required: API secret for protecting the management UI
# Generate with: openssl rand -hex 32
# Do NOT leave empty — the server will refuse to start without this
API_SECRET=

# Optional: CORS origins for the frontend (comma-separated)
# Example: https://cf.example.com,http://localhost:3000
# If empty, CORS will be disabled (recommended for API-only usage)
CORS_ORIGINS=

# Optional: HTTP/SOCKS5 proxy for Cloudflare API requests
# Examples: http://127.0.0.1:7890  socks5://127.0.0.1:1080
PROXY_URL=

# Optional: exposed port on the host (default: 3000)
APP_PORT=3000
